{
  "name": "B2_v3_ring",
  "model": {
    "variant_family": "B",
    "baseline_mode": 2,
    "latent_sizes": [2, 2, 2],
    "encoder_hidden_size": 64,
    "controller_hidden_size": 64,
    "prior_hidden_sizes": [48],
    "posterior_hidden_sizes": [48],
    "message_dim": 8,
    "hidden_input_dim": 4,
    "message_stochastic": false,
    "use_hidden_inputs": true,
    "coupling_mode": "additive",
    "message_source": "task_rate",
    "posterior_correction_scale": 1.0
  },
  "loss": {
    "beta_traj_final": 0.5,
    "beta_message_final": 0.01,
    "beta_hidden_final": 0.1,
    "beta_z0_final": 0.1,
    "beta_baseline": 1.0,
    "warmup_epochs": 50,
    "hidden_ramp_start": 50,
    "hidden_ramp_epochs": 150,
    "message_ramp_start": 100,
    "message_ramp_epochs": 100,
    "traj_ramp_start": 150,
    "traj_ramp_epochs": 100,
    "z0_ramp_start": 50,
    "z0_ramp_epochs": 100,
    "use_kl_floor": true,
    "kl_floor": 0.01
  },
  "optim": {
    "learning_rate": 0.004,
    "weight_decay": 1e-5,
    "grad_clip_norm": 10.0,
    "batch_size": 128,
    "epochs": 300,
    "lr_schedule": "plateau",
    "lr_patience": 6,
    "lr_decay": 0.95,
    "lr_min": 1e-5,
    "log_every": 10,
    "seed": 0
  }
}
